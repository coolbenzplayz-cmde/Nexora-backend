# =========================
# Nexora Environment Template
# Copy this file to .env and set real values
# =========================

# App
APP_ENV=development
APP_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexora
DB_USER=nexora_user
DB_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT / Auth
JWT_SECRET=change_me_super_secret
JWT_EXPIRATION_SECONDS=900
JWT_REFRESH_EXPIRATION_SECONDS=604800
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Security
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
CORS_ALLOWED_ORIGINS=http://localhost:5173
SESSION_MAX_DEVICES=5

# Payment
PAYMENT_PROVIDER=stripe
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Fraud / AI
FRAUD_RISK_THRESHOLD=70
FRAUD_AUTO_FREEZE_THRESHOLD=90

# Storage / Media
MEDIA_STORAGE=local
MEDIA_MAX_FILE_SIZE_MB=25
SIGNED_URL_TTL_SECONDS=300

# Observability
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true

# Deployment
DOCKER_IMAGE_TAG=latest
K8S_NAMESPACE=nexora
